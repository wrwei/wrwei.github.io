digraph VModel {
    graph [
        rankdir=TB
        fontname="Courier New"
        nodesep=1.2
        ranksep=0.6
        bgcolor=white
        margin="0.3,0.2"
        dpi=150
    ]

    node [
        fontname="Courier New"
        fontsize=11
        style="bold,rounded"
        shape=box
        margin="0.25,0.15"
    ]

    edge [
        fontname="Courier New"
        fontsize=9
        color="#475569"
    ]

    /* Left side - Decomposition */
    SysReq [label="System\nRequirements" fillcolor="#DBEAFE" style="filled,bold,rounded"]
    SubReq [label="Subsystem\nRequirements" fillcolor="#DBEAFE" style="filled,bold,rounded"]
    CompReq [label="Component\nRequirements" fillcolor="#DBEAFE" style="filled,bold,rounded"]

    /* Bottom */
    Impl [label="Implementation\n& Coding" fillcolor="#FEF3C7" style="filled,bold,rounded"]

    /* Right side - Integration & Verification */
    CompVer [label="Component\nVerification" fillcolor="#F0FDF4" style="filled,bold,rounded"]
    SubVer [label="Subsystem\nVerification" fillcolor="#F0FDF4" style="filled,bold,rounded"]
    SysVal [label="System\nValidation" fillcolor="#F0FDF4" style="filled,bold,rounded"]

    /* Left side edges (decomposition) */
    SysReq -> SubReq [label="  decompose  " color="#2563EB" fontcolor="#2563EB"]
    SubReq -> CompReq [label="  decompose  " color="#2563EB" fontcolor="#2563EB"]
    CompReq -> Impl [label="  implement  " color="#92400E" fontcolor="#92400E"]

    /* Right side edges (integration) */
    Impl -> CompVer [label="  test  " color="#16A34A" fontcolor="#16A34A"]
    CompVer -> SubVer [label="  integrate  " color="#16A34A" fontcolor="#16A34A"]
    SubVer -> SysVal [label="  integrate  " color="#16A34A" fontcolor="#16A34A"]

    /* Horizontal traceability arrows */
    SysReq -> SysVal [style=dashed color="#94A3B8" label="validates" fontcolor="#94A3B8" constraint=false]
    SubReq -> SubVer [style=dashed color="#94A3B8" label="verifies" fontcolor="#94A3B8" constraint=false]
    CompReq -> CompVer [style=dashed color="#94A3B8" label="verifies" fontcolor="#94A3B8" constraint=false]

    /* Force V shape with ranks */
    { rank=same; SysReq; SysVal }
    { rank=same; SubReq; SubVer }
    { rank=same; CompReq; CompVer }
    { rank=same; Impl }
}
