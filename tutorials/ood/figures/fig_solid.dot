digraph SOLID {
    graph [
        rankdir=TB
        fontname="Courier New"
        nodesep=0.3
        ranksep=0.4
        bgcolor=white
        margin="0.3,0.2"
        dpi=150
    ]

    node [
        shape=record
        fontname="Courier New"
        fontsize=13
        style="bold,rounded"
        margin="0.3,0.2"
    ]

    edge [style=invis]

    S [label="S — Single Responsibility\leach class has one reason to change.\lBook: data/validation.  Order: lifecycle.  Payment: transactions.\l"]
    O [label="O — Open/Closed\lopen for extension, closed for modification.\lNew BookType: subclass Book only. No existing code changes.\l"]
    L [label="L — Liskov Substitution\lsubtypes honour the parent contract.\lDigitalBook/PhysicalBook always usable wherever Book is expected.\l"]
    I [label="I — Interface Segregation\lsmall focused interfaces over one large one.\lPayable, Discountable, Serialisable — each minimal and targeted.\l"]
    D [label="D — Dependency Inversion\ldepend on abstractions, not concretions.\lOrder depends on Book (not DigitalBook). PricingStrategy (not StandardPricing).\l"]

    S -> O -> L -> I -> D
}
